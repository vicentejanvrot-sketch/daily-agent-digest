{
  "expo": {
    "name": "Daily Agent Digest",
    "slug": "je0yu8oeyjzcpim4k10q0",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "rork-app",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0fa0e6"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.rork.je0yu8oeyjzcpim4k10q0"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0fa0e6"
      },
      "package": "app.rork.je0yu8oeyjzcpim4k10q0"
    },
    "web": {
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro",
      "output": "single",
      "name": "Daily Agent Digest",
      "shortName": "Daily Agent Digest",
      "description": "Daily Agent Digest — AI agents that scan your channels and surface the new videos worth watching, all in one daily feed.",
      "themeColor": "#0B1220",
      "backgroundColor": "#0B1220",
      "display": "standalone"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://rork.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
